{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regula.app/content.schema.json",
  "title": "Regula Content",
  "type": "object",
  "required": ["contentVersion", "categories", "entries"],
  "properties": {
    "contentVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Bump this integer whenever you change content and want installed apps to reload."
    },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/$defs/category" }
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "category": {
      "type": "object",
      "required": ["id", "name", "sortOrder"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "name": { "type": "string", "minLength": 1 },
        "sortOrder": { "type": "integer", "minimum": 0 }
      }
    },
    "entry": {
      "type": "object",
      "required": [
        "id",
        "categoryId",
        "question",
        "shortAnswer",
        "classification",
        "classificationNote",
        "citations"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "categoryId": { "type": "string" },
        "question": { "type": "string", "minLength": 1 },
        "shortAnswer": { "type": "string", "minLength": 1 },
        "classification": {
          "type": "string",
          "enum": ["dogma", "doctrine", "discipline", "theological_opinion"]
        },
        "classificationNote": { "type": "string", "minLength": 1 },
        "citations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/citation" }
        }
      }
    },
    "citation": {
      "type": "object",
      "required": ["sourceType", "reference", "summary"],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["ccc", "canon_law", "aquinas", "magisterial", "scripture"]
        },
        "reference": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
